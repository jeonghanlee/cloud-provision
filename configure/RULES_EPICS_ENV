##@ EPICS-env source build

.PHONY: epics-env epics-env.provision help.epics-env

# Provision both epics-env VMs (dedicated .120 / .20 block, EPICS_ENV_RAM MB
# each) and build EPICS-env from source on each via ansible-provision. Both the
# VM provisioning and the ansible role are idempotent, so re-running is safe.
epics-env: epics-env.provision ## Provision both epics-env VMs and build EPICS-env from source
	$(QUIET) cd $(ANSIBLE_DIR) && ansible-playbook -i $(EPICS_ENV_INVENTORY) $(EPICS_ENV_PLAYBOOK) --limit epics_env_build

epics-env.provision: ## Provision the two epics-env VMs without building
	$(QUIET) $(CREATE_VM) -o epics-env-rocky8   -n server -d $(IMAGE_DIR) -m $(EPICS_ENV_RAM)
	$(QUIET) $(CREATE_VM) -o epics-env-debian13 -n server -d $(IMAGE_DIR) -m $(EPICS_ENV_RAM)

help.epics-env: ## Show the epics-env source-build workflow
	$(QUIET) printf "\nEPICS-env from-source build (%s MB RAM per VM):\n" "$(EPICS_ENV_RAM)"
	$(QUIET) printf "  make epics-env            Provision both VMs and build EPICS-env from source\n"
	$(QUIET) printf "  make epics-env.provision  Provision the two VMs only\n"
