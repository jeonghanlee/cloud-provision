CHECK_TOOLS := virsh qemu-img genisoimage virt-install uuidgen

VARS_EXCLUDES += CHECK_TOOLS

##@ Host Setup

.PHONY: setup check-tools check-required-group

setup: ## Verify and install host virtualization prerequisites
	$(QUIET) REQUIRED_GROUP="$(REQUIRED_GROUP)" $(SETUP_HOST)

check-tools: ## Verify required host tools are present (hints make setup on failure)
	$(QUIET) missing=""; \
	for tool in $(CHECK_TOOLS); do \
	    command -v "$$tool" >/dev/null 2>&1 || missing="$$missing $$tool"; \
	done; \
	if [ -n "$$missing" ]; then \
	    printf "%s\n" "error: missing required tools:$$missing"; \
	    printf "%s\n" "install the virtualization stack with: make setup"; \
	    exit 1; \
	fi; \
	printf "%s\n" "all required host tools present: $(CHECK_TOOLS)"

check-required-group: ## Verify required group configuration is shared
	$(QUIET) test "$(REQUIRED_GROUP)" = "libvirt"
	$(QUIET) grep -F 'declare -g REQUIRED_GROUP="$${REQUIRED_GROUP:-libvirt}"' $(CREATE_VM) >/dev/null
	$(QUIET) grep -F 'declare -g REQUIRED_GROUP="$${REQUIRED_GROUP:-libvirt}"' $(SETUP_HOST) >/dev/null
	$(QUIET) ! grep -F 'libvirt group' $(SETUP_HOST) >/dev/null
	$(QUIET) ! grep -F 'usermod -aG libvirt' $(SETUP_HOST) >/dev/null
	$(QUIET) output="$$(REQUIRED_GROUP=cloud-provision-test-group USER="$${USER}" $(CREATE_VM) -h 2>&1 || true)"; \
	printf "%s\n" "$$output" | grep -F "cloud-provision-test-group" >/dev/null
	$(QUIET) printf "%s\n" "required group is shared: $(REQUIRED_GROUP)"
